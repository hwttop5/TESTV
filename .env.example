# Maintenance database
# Used only by local sync/backfill/export scripts. The production web app reads
# public-catalog/products.json and does not require DATABASE_URL at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/youtube_reviews?schema=public"

# YouTube Data API
YOUTUBE_API_KEY="your_youtube_api_key_here"
YOUTUBE_PLAYLIST_ID="PLWAtCzJzHiz8e1itWCrJuMVqBDYUI6yd7"
# Or paste the full playlist URL instead of the ID.
# YOUTUBE_PLAYLIST_URL="https://www.youtube.com/playlist?list=PLWAtCzJzHiz8e1itWCrJuMVqBDYUI6yd7"

# Product extraction
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"
# Optional local-only fallback. Keep false for open-source/default use.
# USE_CODEX_MANAGER_OPENAI="false"
EXTRACTION_BATCH_SIZE="10"
EXTRACTION_MAX_ATTEMPTS="3"
# Set to true when re-running old products that are missing Chinese display fields.
REPROCESS_MISSING_CHINESE="false"

# Transcript and audio transcription fallback
TRANSCRIPT_BATCH_SIZE="20"
TRANSCRIPT_MAX_ATTEMPTS="3"
ENABLE_AUDIO_TRANSCRIPTION="true"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"
YTDLP_BIN="yt-dlp"
# YTDLP_COOKIES_FILE="/absolute/path/to/youtube-cookies.txt"
# YTDLP_COOKIES_FROM_BROWSER="chrome"
# YTDLP_JS_RUNTIMES="node"
# YTDLP_REMOTE_COMPONENTS="ejs:github"
# KEEP_AUDIO_FILES="false"
BILIBILI_PREFERRED_MID="11336264"
# Point to a local private UTF-8 text file that contains the full Cookie header.
# BILIBILI_COOKIE_FILE="C:\\path\\to\\bilibili-cookie.txt"
# BILIBILI_BATCH_SIZE="10"
# BILIBILI_FORCE_RETRY="false"
# BILIBILI_INCLUDE_ALL_UNRESOLVED="true"
ASR_BATCH_SIZE="5"
# ASR_LIMIT="10"
# ASR_MARK_TERMINAL="false"
# LOCAL_ASR_BATCH_SIZE="2"
# LOCAL_ASR_FORCE_RETRY="false"
# FASTER_WHISPER_MODEL="small"
# FASTER_WHISPER_COMPUTE_TYPE="int8"
# FASTER_WHISPER_DEVICE="cuda"

# Continuous processing mode (drain queue until empty)
CONTINUOUS_MODE="false"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Baidu Tongji hm.js id, not the Baidu siteId.
# NEXT_PUBLIC_BAIDU_TONGJI_ID="your_baidu_tongji_id_here"
