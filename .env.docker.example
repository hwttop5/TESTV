# Docker Compose production runtime
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-domain.example"
NEXT_PUBLIC_BAIDU_TONGJI_ID="your_baidu_tongji_id_here"
APP_PORT="3000"
APP_IMAGE="your-app-image:latest"

# Public runtime data
# The app reads this JSON snapshot from the image by default. Override only if
# you mount a different vetted snapshot path into the container.
# PUBLIC_CATALOG_PATH="/app/public-catalog/products.json"

# Optional VPS deploy variables used by .github/workflows/deploy-vps.yml
VPS_STACK_DIR="/opt/stacks/example-app"
VPS_DATA_DIR="/srv/example-app"
CADDY_NETWORK="caddy_proxy"
APP_NETWORK_ALIAS="app"

# Maintenance-only settings
# Keep these in local .env when running sync/backfill/export scripts. They are
# not needed for the production web process.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/youtube_reviews?schema=public"
# YOUTUBE_API_KEY="your_youtube_api_key_here"
# YOUTUBE_PLAYLIST_ID="PLWAtCzJzHiz8e1itWCrJuMVqBDYUI6yd7"
# OPENAI_API_KEY="your_openai_api_key_here"
# OPENAI_MODEL="gpt-4o-mini"
