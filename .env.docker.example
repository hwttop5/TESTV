# Docker Compose runtime
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-domain.example"
NEXT_PUBLIC_BAIDU_TONGJI_ID="your_baidu_tongji_id_here"
APP_PORT="3000"
APP_IMAGE="your-app-image:latest"

# PostgreSQL container settings
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-this-password"
POSTGRES_DB="youtube_reviews"
POSTGRES_PORT="5432"

# The app service overrides DATABASE_URL to use the internal postgres hostname.
# Keep this value for running scripts from the host, or copy it into .env when
# you intentionally run against the Compose database from the host machine.
DATABASE_URL="postgresql://postgres:change-this-password@localhost:5432/youtube_reviews?schema=public"

# YouTube Data API
YOUTUBE_API_KEY="your_youtube_api_key_here"
YOUTUBE_PLAYLIST_ID="PLWAtCzJzHiz8e1itWCrJuMVqBDYUI6yd7"
# YOUTUBE_PLAYLIST_URL="https://www.youtube.com/playlist?list=PLWAtCzJzHiz8e1itWCrJuMVqBDYUI6yd7"

# Product extraction and AI-assisted cleanup
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"
# Do not enable Codex Manager lookup in Docker/production.
# USE_CODEX_MANAGER_OPENAI="false"
EXTRACTION_BATCH_SIZE="10"
EXTRACTION_MAX_ATTEMPTS="3"
REPROCESS_MISSING_CHINESE="false"

# Transcript and ASR settings are only needed when manually running sync scripts.
TRANSCRIPT_BATCH_SIZE="20"
TRANSCRIPT_MAX_ATTEMPTS="3"
ENABLE_AUDIO_TRANSCRIPTION="false"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"
YTDLP_BIN="yt-dlp"
# YTDLP_COOKIES_FILE="/absolute/path/to/youtube-cookies.txt"
# YTDLP_COOKIES_FROM_BROWSER="chrome"
BILIBILI_PREFERRED_MID="11336264"
# BILIBILI_COOKIE_FILE="/absolute/path/to/bilibili-cookie.txt"
ASR_BATCH_SIZE="5"
CONTINUOUS_MODE="false"

# Optional VPS deploy variables used by .github/workflows/deploy-vps.yml
VPS_STACK_DIR="/opt/stacks/example-app"
VPS_DATA_DIR="/srv/example-app"
CADDY_NETWORK="caddy_proxy"
APP_NETWORK_ALIAS="app"
