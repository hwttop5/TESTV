generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id                 String   @id @default(cuid())
  youtubeId          String   @unique
  title              String
  publishedAt        DateTime
  thumbnailUrl       String?
  videoUrl           String
  syncStatus         String   @default("pending") // pending, transcript_synced, extracted, failed
  transcriptStage    String   @default("pending") // pending, browser_failed, ytdlp_failed, asr_failed, synced, terminal
  transcriptAttempts Int      @default(0)
  browserAttemptCount Int     @default(0)
  ytdlpAttemptCount   Int     @default(0)
  asrAttemptCount     Int     @default(0)
  extractionAttempts Int      @default(0)
  lastTranscriptAt   DateTime?
  lastExtractedAt    DateTime?
  lastError          String?  @db.Text
  isAvailable        Boolean  @default(true)
  unavailableReason  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transcripts Transcript[]
  product     Product?

  @@index([publishedAt])
  @@index([syncStatus])
  @@index([transcriptStage])
  @@index([transcriptAttempts])
  @@index([extractionAttempts])
  @@index([isAvailable])
}

model Transcript {
  id        String   @id @default(cuid())
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  source     String
  language   String   @default("en")
  segments   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([videoId])
}

model Product {
  id                 String   @id @default(cuid())
  videoId            String   @unique
  video              Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  productName        String
  scoreRaw           String?
  scoreValue         Float?
  scoreScale         String?
  normalizedScore    Float?
  priceRaw           String?
  priceValue         Float?
  priceCurrency      String?
  priceType          String?
  priceContext       String?  @db.Text
  priceConfidence    Float?
  pros               Json
  cons               Json
  evidenceSegments   Json?
  productNameZh      String?
  videoTitleZh       String?
  prosZh             Json?
  consZh             Json?
  evidenceSegmentsZh Json?
  confidence         Float?
  published          Boolean  @default(false)
  contentStatus      String   @default("placeholder") // complete, partial, placeholder
  affiliateLinks     AffiliateLink[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([contentStatus, normalizedScore])
  @@index([published, normalizedScore])
  @@index([published, createdAt])
}

model AffiliateLink {
  id        String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform   String
  url        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}

model SyncRun {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  status          String
  videosProcessed Int      @default(0)
  videosSuccess   Int      @default(0)
  videosFailed    Int      @default(0)
  errorMessage    String?  @db.Text
  errorDetails    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([startedAt])
  @@index([status])
}
